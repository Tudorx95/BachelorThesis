      "updated": 1781357503759,
      "link": null,
      "locked": false,
      "text": "tests/\n└── test{X}/\n    ├── template_code.py\n    ├── simulation_config.json\n    ├── {NN_NAME}.keras  (sau .pth)\n    ├── init-verification.json\n    ├── clean_data/\n    │   └── data/ (datele brute descărcate, pe clase)\n    ├── data_distribution_clean/\n    │   ├── validation.json\n    │   └── client_0..N.json (mapări date non-IID per client)\n    ├── data_distribution_poisoned/\n    │   ├── validation.json\n    │   └── client_0..N.json (mapări cu redirecționare pt. atac)\n    ├── clean_data_poisoned/\n    │   └── R0..R_{n-1}/ (organizare pe runde de antrenare)\n    │       └── client_M/ (date efectiv alterate pt. clienții malițioși)\n    └── results/\n        ├── clean_metrics.json\n        ├── clean_dp_metrics.json\n        ├── poisoned_metrics.json\n        ├── attack_info.json\n        ├── poisoned_dp_metrics.json\n        ├── analysis.json\n        └── summary.txt\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "tests/\n└── test{X}/\n    ├── template_code.py\n    ├── simulation_config.json\n    ├── {NN_NAME}.keras  (sau .pth)\n    ├── init-verification.json\n    ├── clean_data/\n    │   └── data/ (datele brute descărcate, pe clase)\n    ├── data_distribution_clean/\n    │   ├── validation.json\n    │   └── client_0..N.json (mapări date non-IID per client)\n    ├── data_distribution_poisoned/\n    │   ├── validation.json\n    │   └── client_0..N.json (mapări cu redirecționare pt. atac)\n    ├── clean_data_poisoned/\n    │   └── R0..R_{n-1}/ (organizare pe runde de antrenare)\n    │       └── client_M/ (date efectiv alterate pt. clienții malițioși)\n    └── results/\n        ├── clean_metrics.json\n        ├── clean_dp_metrics.json\n        ├── poisoned_metrics.json\n        ├── attack_info.json\n        ├── poisoned_dp_metrics.json\n        ├── analysis.json\n        └── summary.txt\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
